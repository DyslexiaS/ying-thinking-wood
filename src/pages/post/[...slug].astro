---
import { type CollectionEntry } from 'astro:content'
import BlogPost from '@/layouts/BlogPost'
import Code from '@/components/mdx/Code'
import TableOfContents from '@/components/TableOfContents'
import { getPosts } from '@/utils'
import SButton from '@/components/mdx/SButton'
import { Image } from 'astro:assets'

export async function getStaticPaths() {
	const posts = await getPosts()

	return posts.map((post, index) => ({
		params: { slug: post.slug },
		props: {
			post,
			prevPost: index + 1 < posts.length ? posts[index + 1] : null,
			nextPost: index - 1 >= 0 ? posts[index - 1] : null
		}
	}))
}

type Props = {
	post: CollectionEntry<'blog'>
	prevPost: CollectionEntry<'blog'> | null
	nextPost: CollectionEntry<'blog'> | null
}

const { post, prevPost, nextPost } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await post.render()
---

<BlogPost
	id={post.id}
	data={post.data}
	headings={headings}
	readTime={remarkPluginFrontmatter.minutesRead}
>
	<div class='grid grid-cols-1 md:grid-cols-[20%_auto] gap-10 mt-8'>
		<!-- aside -->
		<aside class='md:flex flex-col hidden'>
			<div class='sticky top-24 self-start hidden md:block transition-all duration-200'>
				{headings && headings.length > 0 && <TableOfContents {headings} />}
			</div>
		</aside>

		<!-- post -->
		<article class='max-w-full w-full'>
			{
				post.data.heroImage && (
					<Image
						src={post.data.heroImage}
						width={1000}
						height={500}
						quality={100}
						format='jpg'
						loading='eager'
						class='rounded-md w-full max-h-[300px] md:max-h-[500px] mb-8 object-cover'
						style='filter: sepia(10%) saturate(88%);'
						alt={`img of ${post.data.title}`}
					/>
				)
			}
			<div class='prose prose-lg md:prose-xl dark:prose-invert mb-12 min-w-full'>
				<Content components={{ pre: Code, SButton }} />
			</div>

			<!-- prev / next navigation -->
			<nav
				class='flex items-stretch justify-between gap-6 pt-10 mt-6'
				style='border-top: 1px solid var(--border);'
			>
				{
					prevPost ? (
						<a
							href={`/post/${prevPost.slug}/`}
							class='group flex flex-col gap-2 max-w-[48%] px-5 py-4 rounded-xl transition-shadow duration-200 hover:shadow-md'
							style='border: 1px solid var(--border); background-color: var(--bg-card);'
						>
							<span
								class='text-xs font-semibold uppercase tracking-widest'
								style='color: var(--text-muted);'
							>
								← Previous
							</span>
							<span
								class='text-base font-semibold leading-snug group-hover:underline underline-offset-2'
								style='color: var(--text);'
							>
								{prevPost.data.title}
							</span>
						</a>
					) : (
						<div />
					)
				}
				{
					nextPost && (
						<a
							href={`/post/${nextPost.slug}/`}
							class='group flex flex-col gap-2 items-end text-right max-w-[48%] ml-auto px-5 py-4 rounded-xl transition-shadow duration-200 hover:shadow-md'
							style='border: 1px solid var(--border); background-color: var(--bg-card);'
						>
							<span
								class='text-xs font-semibold uppercase tracking-widest'
								style='color: var(--text-muted);'
							>
								Next →
							</span>
							<span
								class='text-base font-semibold leading-snug group-hover:underline underline-offset-2'
								style='color: var(--text);'
							>
								{nextPost.data.title}
							</span>
						</a>
					)
				}
			</nav>
		</article>
	</div>
</BlogPost>
