---
import HeaderLink from '@/components/HeaderLink'
import MenuIcon from './icons/MenuIcon.astro'
import Search from '@/components/Search'
import ToggleTheme from './ToggleTheme.astro'
import { siteConfig } from '@/site-config'
---

<header
	class='relative grid grid-cols-3 items-center h-24 px-2'
	style='border-bottom: 1px solid var(--border);'
>
	<!-- Left: nav links -->
	<nav
		class='hidden md:flex items-center gap-8 text-sm font-bold uppercase tracking-widest'
		style='color: var(--text);'
	>
		<HeaderLink href='/' class='hover:opacity-60 transition-opacity duration-150'>Home</HeaderLink>
		<!-- 
		<HeaderLink href='/tags' class='hover:opacity-60 transition-opacity duration-150'>
			Tags
		</HeaderLink>
		-->
		<HeaderLink href='/rss.xml' class='hover:opacity-60 transition-opacity duration-150'>
			RSS
		</HeaderLink>
	</nav>

	<!-- Mobile: hamburger on the left -->
	<div class='md:hidden flex items-center'>
		<button id='astro-header-drawer-button' type='button' style='color: var(--text-muted);'>
			<MenuIcon />
			<span class='sr-only'>Show Menu</span>
		</button>
	</div>

	<!-- Center: site title -->
	<a
		href='/'
		class='text-3xl md:text-4xl font-bold tracking-wide text-center justify-self-center hover:opacity-70 transition-opacity duration-150'
		style='color: var(--text);'
	>
		{siteConfig.title}
	</a>

	<!-- Right: search + theme toggle -->
	<div class='flex items-center gap-3 justify-self-end' transition:persist='navbar'>
		<Search />
		<ToggleTheme />
	</div>
</header>

<!-- Mobile drawer -->
<div
	id='astro-header-mobile-drawer'
	class='hidden flex-col gap-3 px-6 py-4 md:hidden'
	style='background-color: var(--bg); border-bottom: 1px solid var(--border);'
>
	<HeaderLink
		href='/'
		class='text-sm font-semibold uppercase tracking-widest'
		style='color: var(--text-muted);'
	>
		Home
	</HeaderLink>
	<!--
	<HeaderLink
		href='/tags'
		class='text-sm font-semibold uppercase tracking-widest'
		style='color: var(--text-muted);'
	>
		Tags
	</HeaderLink>
	-->
	<HeaderLink
		href='/rss.xml'
		class='text-sm font-semibold uppercase tracking-widest'
		style='color: var(--text-muted);'
	>
		RSS
	</HeaderLink>
</div>

<script>
	document.addEventListener('click', (event) => {
		const btn = document.getElementById('astro-header-drawer-button')
		const drawer = document.getElementById('astro-header-mobile-drawer')
		if (btn?.contains(event.target as Node)) {
			drawer?.classList.toggle('hidden')
			drawer?.classList.toggle('flex')
		} else if (!drawer?.contains(event.target as Node)) {
			drawer?.classList.add('hidden')
			drawer?.classList.remove('flex')
		}
	})
</script>
