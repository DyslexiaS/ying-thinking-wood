---
import { Image } from 'astro:assets'
import { siteConfig } from '@/site-config'
import avatarImage from '../assets/images/avatar.jpg'

const {
	data: { title, description, heroImage },
	slug,
	readTime
} = Astro.props
---

<a
	href={`/post/${slug}/`}
	class='group flex flex-col rounded-xl overflow-hidden transition-shadow duration-200 hover:shadow-lg cursor-pointer'
	style='background-color: var(--bg-card); border: 1px solid var(--border);'
	aria-label={title}
>
	<div class='overflow-hidden'>
		<Image
			src={heroImage}
			width={600}
			height={300}
			format='webp'
			class='w-full h-56 object-cover group-hover:scale-[102%] transition-transform duration-300'
			style='filter: sepia(8%) saturate(90%);'
			alt={`img of ${title}`}
		/>
	</div>

	<div class='flex flex-col gap-2 flex-1 px-5 py-4'>
		<p class='text-xl font-semibold leading-snug' style='color: var(--text);'>
			{title}
		</p>

		<p class='text-sm line-clamp-3 leading-relaxed flex-1' style='color: var(--text-muted);'>
			{description}
		</p>

		<div class='flex items-center justify-between mt-3'>
			<div class='flex items-center gap-3'>
				<span class='text-xs font-semibold uppercase tracking-widest' style='color: var(--accent);'>
					Read More
				</span>
				{
					readTime && (
						<span class='text-xs' style='color: var(--text-muted);'>
							{readTime}
						</span>
					)
				}
			</div>

			<Image
				src={avatarImage}
				width={80}
				height={80}
				format='webp'
				class='w-10 h-10 rounded-full object-cover object-[50%_15%] shrink-0'
				style='border: 1px solid var(--border);'
				alt={siteConfig.author}
				title={siteConfig.author}
			/>
		</div>
	</div>
</a>
